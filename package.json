{
  "name": "tmp-moodify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "patch-package && prisma generate",
    "start": "next start",
    "lint": "eslint",
    "cf:build": "npx @opennextjs/cloudflare build --skipWranglerConfigCheck",
    "cf:deploy": "npx @opennextjs/cloudflare deploy --skipWranglerConfigCheck",
    "cf:preview": "npx @opennextjs/cloudflare preview",
    "cf:upload": "npx @opennextjs/cloudflare upload --skipWranglerConfigCheck",
    "test:e2e": "playwright test tests/e2e",
    "test:api": "playwright test tests/api",
    "test:a11y": "playwright test tests/accessibility --project=chromium",
    "test:visual": "playwright test tests/visual --project=chromium",
    "test:visual:update": "playwright test tests/visual --project=chromium --update-snapshots",
    "test:perf": "cross-env RUN_LIGHTHOUSE=1 playwright test tests/performance --project=chromium",
    "test:qa": "playwright test --project=chromium",
    "test:qa:all": "playwright test",
    "playwright:install": "playwright install"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.100.10",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "inngest": "^4.5.0",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "pg": "^8.20.0",
    "pg-cloudflare": "^1.4.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "chrome-launcher": "^1.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "lighthouse": "^13.4.0",
    "patch-package": "^8.0.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "wait-on": "^9.0.10",
    "wrangler": "^4.106.0"
  }
}
