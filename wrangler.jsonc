{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "melo",
  "compatibility_date": "2026-07-02",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  }
}
